rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper function to check if user is the designated admin
    function isAdmin() {
      return request.auth != null && (
        request.auth.token.email.matches('.*@gmail\\.com') ||
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin')
      );
    }

    // Helper function to check if request is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }

    // 0. Users: Each authenticated user can read/write their own profile only
    match /users/{userId} {
      allow read: if isAuthenticated();
      allow create, update: if isAuthenticated() && request.auth.uid == userId;
      allow delete: if isAdmin();
    }

    // 1. Products: Publicly readable, admin-only write
    match /products/{document} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // 2. Banners: Publicly readable, admin-only write
    match /banners/{document} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // 3. Categories: Publicly readable, admin-only write
    match /categories/{document} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // 4. Service Categories: Publicly readable, admin-only write
    match /service_categories/{document} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // 5. Businesses: Publicly readable, anyone can register a new listing (starts unverified)
    match /businesses/{document} {
      allow read: if true;
      // Allow creation of new listings (forces verified to be false unless admin creates it)
      allow create: if isAdmin() || (request.resource.data.verified == false);
      // Only the admin or the original listing owner can update/delete
      allow update, delete: if isAdmin() || (isAuthenticated() && resource.data.ownerEmail == request.auth.token.email);
    }

    // 6. Print Orders: Readable by admin and users who created them.
    // Note: Due to client-side global query design on page load, read is set to public to prevent console errors.
    match /print_orders/{document} {
      allow read: if true;
      allow create: if true;
      allow update, delete: if isAdmin();
    }

    // 7. Settings: Publicly readable, admin-only write
    match /settings/{document} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // 8. Branding Partners: Publicly readable, admin-only write
    match /branding_partners/{document} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // 9. Hashtag Orders: Publicly readable, anyone can submit orders, admin-only update/delete
    match /hashtag_orders/{document} {
      allow read: if true;
      allow create: if true;
      allow update, delete: if isAdmin();
    }

    // 10. Notifications: Publicly readable, anyone can create, admin-only update/delete
    match /notifications/{document} {
      allow read, create: if true;
      allow update, delete: if isAdmin();
    }
  }
}

